# ═══════════════════════════════════════════════════════════════════════════════
# FrugaLLM 2.0 — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys.
# Only OPENROUTER_API_KEY is required for basic operation.
# ═══════════════════════════════════════════════════════════════════════════════

# =============================================================================
# REQUIRED: OpenRouter API Key
# =============================================================================
# OpenRouter provides access to many models through one API.
# The Dynamic Roster Sidecar uses this to discover and route through
# the best available free models automatically.
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# =============================================================================
# OPTIONAL: Separate Management Key for Model Polling
# =============================================================================
# If you want to use a separate API key for polling the OpenRouter /models API
# (to keep rate limits separate from inference), set this.
# If not set, the sidecar falls back to OPENROUTER_API_KEY.
# OPENROUTER_MANAGEMENT_KEY=sk-or-v1-your-management-key-here

# =============================================================================
# OPTIONAL: Google Gemini (Paid Fallback)
# =============================================================================
# Native Gemini API for paid fallback tiers.
# Get your key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-gemini-key-here

# =============================================================================
# FRUGALLM CONFIGURATION
# =============================================================================
# These control the FrugaLLM proxy and sidecar behavior.

# LiteLLM proxy port (default: 4000)
# FRUGALLM_PROXY_PORT=4000

# LiteLLM proxy URL for the CLI (default: http://127.0.0.1:4000)
# FRUGALLM_PROXY_URL=http://127.0.0.1:4000

# Master key for authenticating with the LiteLLM proxy
# CHANGE THIS for production use!
# FRUGALLM_MASTER_KEY=sk-frugallm-master

# Config directory containing litellm_config.yaml (default: ./config)
# FRUGALLM_CONFIG_DIR=./config

# Sidecar poll interval in seconds (default: 300 = 5 minutes)
# FRUGALLM_POLL_INTERVAL=300

# =============================================================================
# LOCAL MODEL CONFIGURATION
# =============================================================================
# Local Ollama model used as the final fallback when all cloud models fail.

# Ollama model name (default: llama3.2:latest)
# FRUGALLM_LOCAL_MODEL=llama3.2:latest

# Ollama base URL (default: http://127.0.0.1:11434)
# FRUGALLM_LOCAL_URL=http://127.0.0.1:11434

# =============================================================================
# OPTIONAL: GPU NODE CONFIGURATION
# =============================================================================
# If you have a dedicated GPU node (e.g., via Tailscale), configure it here.
# The sidecar will use this as the reasoning chain's final fallback.

# GPU node model path (leave empty to disable)
# FRUGALLM_GPU_MODEL=/models/your-model.gguf
# FRUGALLM_GPU_URL=http://YOUR_GPU_IP:8080/v1

# =============================================================================
# OPTIONAL: TELEMETRY (Langfuse)
# =============================================================================
# LiteLLM ships traces, token usage, latency, and costs automatically
# when Langfuse callbacks are enabled in litellm_config.yaml.
# LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
# LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
# LANGFUSE_HOST=https://us.cloud.langfuse.com

# =============================================================================
# OPTIONAL: DATABASE (PostgreSQL for Spend Logging)
# =============================================================================
# LiteLLM can log all spend data to PostgreSQL for analytics.
# DATABASE_URL=postgresql://litellm:your_password@127.0.0.1:5432/litellm
